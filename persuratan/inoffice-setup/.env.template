APP_NAME="inOffice Persuratan RSU UKI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE — Ubah sesuai konfigurasi server
# ============================================
# Pilihan 1: SQLite (untuk development lokal cepat)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Pilihan 2: PostgreSQL (untuk production — sesuai PRD)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=inoffice_rsuuki
# DB_USERNAME=postgres
# DB_PASSWORD=your_password_here

# ============================================
# MAIL — Konfigurasi SMTP untuk notifikasi email
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@rsuuki.ac.id
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@rsuuki.ac.id"
MAIL_FROM_NAME="inOffice RSU UKI"

# ============================================
# QUEUE — Untuk email async
# ============================================
QUEUE_CONNECTION=database

# ============================================
# FILESYSTEM — Upload file scan surat
# ============================================
FILESYSTEM_DISK=local
# Untuk production, bisa pakai S3 atau MinIO:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=inoffice-rsuuki

# ============================================
# SESSION
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_EXPIRE_ON_CLOSE=false

# ============================================
# CACHE
# ============================================
CACHE_DRIVER=file

# ============================================
# MAX FILE UPLOAD (75 MB per PRD)
# ============================================
MAX_UPLOAD_SIZE_MB=75
